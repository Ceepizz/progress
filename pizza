local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TeleportService = game:GetService("TeleportService")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
local RemoteFunction = ReplicatedStorage:WaitForChild("RemoteFunction")

local LOBBY_PLACE_ID = 3260590327
local TELEPORT_AFTER_SECONDS = 7200

local activeStratThread = nil
local stratRunning = false
local teleported = false

local function TeleportLobby()
    if teleported then return end
    teleported = true

    print("Teleporting to TDS lobby...")

    local success, err = pcall(function()
        TeleportService:Teleport(LOBBY_PLACE_ID, LocalPlayer)
    end)

    if not success then
        warn("Teleport failed:", err)
        teleported = false
    end
end

local function RewardScreenDetected()
    local success, detected = pcall(function()
        local uiRoot = PlayerGui:FindFirstChild("ReactGameNewRewards")
        if not uiRoot then
            return false
        end

        if uiRoot:FindFirstChild("RewardsScreen", true) then
            return true
        end

        if uiRoot:FindFirstChild("gameOver", true) then
            return true
        end

        return false
    end)

    return success and detected
end

local function FireVotingSkip()
    print("Firing Voting Skip...")

    for i = 1, 5 do
        local success, err = pcall(function()
            RemoteFunction:InvokeServer("Voting", "Skip")
        end)

        if success then
            print("Voting Skip fired:", i)
        else
            warn("Voting Skip failed:", err)
        end

        task.wait(0.5)
    end
end

local function StartStrategy()
    if stratRunning then
        print("Strategy already running")
        return
    end

    stratRunning = true
    print("Starting strategy...")

    local ok, err = pcall(function()
        TDS:ResetIndex()

        task.spawn(function()
            pcall(function()
                TDS:Ready()
            end)
        end)

        task.wait(3)

        print("Starting placement...")

        for i = 1, 15 do
            TDS:Place("Assassin", 4.272305488586426, 1.0368714332580566, -31.2442684173584, true)
        end

        for towerIndex = 1, 4 do
            for i = 1, 4 do
                TDS:Upgrade(towerIndex)
            end
        end

        for towerIndex = 5, 15 do
            for i = 1, 2 do
                TDS:Upgrade(towerIndex)
            end
        end

        for i = 1, 25 do
            TDS:Place("Assassin", 4.272305488586426, 1.0368714332580566, -31.2442684173584, true)
        end

        for towerIndex = 16, 40 do
            for i = 1, 2 do
                TDS:Upgrade(towerIndex)
            end
        end

        print("Strategy finished.")
    end)

    if not ok then
        warn("Strategy error:", err)
    end

    stratRunning = false
end

task.spawn(function()
    task.wait(TELEPORT_AFTER_SECONDS)

    print("2 hours reached. Force teleporting to TDS lobby...")

    if activeStratThread and coroutine.status(activeStratThread) ~= "dead" then
        task.cancel(activeStratThread)
        activeStratThread = nil
    end

    stratRunning = false
    TeleportLobby()
end)

task.spawn(function()
    activeStratThread = task.spawn(StartStrategy)

    local handledRewardScreen = false

    while not teleported do
        task.wait(0.5)

        if RewardScreenDetected() and not handledRewardScreen then
            handledRewardScreen = true

            print("Reward screen detected!")

            if activeStratThread and coroutine.status(activeStratThread) ~= "dead" then
                task.cancel(activeStratThread)
                activeStratThread = nil
            end

            stratRunning = false

            FireVotingSkip()

            print("Waiting for reward screen to disappear...")

            repeat
                task.wait(1)
            until not RewardScreenDetected() or teleported

            if teleported then
                break
            end

            task.wait(2)

            print("Restarting strategy...")
            handledRewardScreen = false
            activeStratThread = task.spawn(StartStrategy)
        end
    end
end)
