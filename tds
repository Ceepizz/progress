local function RunAutoProgression()
    if running then return end
    running = true

    print("Auto progression started")

    local level = GetStat("Level")
    local coins = GetStat("Coins")

    if level >= 50 then
        local hasPyro = HasTower("Pyromancer")
        local hasHunter = HasTower("Hunter")

        if hasPyro and hasHunter then
            RunHardcore()
        else
            if coins >= 2250 then
                if not hasPyro then
                    BuyTower("Pyromancer")
                    task.wait(1)
                end

                if not hasHunter then
                    BuyTower("Hunter")
                    task.wait(1)
                end

                if HasTower("Pyromancer") and HasTower("Hunter") then
                    print("Pyromancer and Hunter bought")
                    RunHardcore()
                else
                    RunPizza()
                end
            else
                RunPizza()
            end
        end

    elseif level <= 24 then
        if HasTower("Assassin") then
            RunAdvanced()
        else
            if coins >= 800 then
                BuyTower("Assassin")
                task.wait(1)

                if HasTower("Assassin") then
                    print("Assassin bought")
                    RunAdvanced()
                else
                    RunEasy()
                end
            else
                RunEasy()
            end
        end

    else
        if HasTower("Assassin") then
            RunPizza()
        else
            RunEasy()
        end
    end

    running = false
end

